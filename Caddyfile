# ── eActive Resource Hub — Caddyfile ─────────────────────────
# CADDY_DOMAIN 환경변수로 도메인을 주입합니다.
# .env 파일에 CADDY_DOMAIN=hub.example.com 형태로 설정하세요.
# DNS A 레코드가 이 서버 IP를 가리켜야 Let's Encrypt 인증서가 자동 발급됩니다.

{env.CADDY_DOMAIN} {
    reverse_proxy app:8080

    encode gzip

    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 10
        }
        format json
    }
}
