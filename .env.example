# ─── PostgreSQL ───────────────────────────────────────────────
# docker-compose가 사용하는 DB 비밀번호 (운영: 강력한 랜덤 값 사용)
POSTGRES_PASSWORD=changeme

# ─── Spring Boot Datasource ───────────────────────────────────
# 컨테이너 내부에서는 docker-compose.yml이 자동 주입
# 로컬에서 gradlew bootRun 시 아래 값이 사용됨
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/resourcehub
SPRING_DATASOURCE_USERNAME=resourcehub
SPRING_DATASOURCE_PASSWORD=changeme

# ─── 업로드 스토리지 ──────────────────────────────────────────
# 로컬: ./storage/uploads  /  운영 VM: /data/eactive-resource-hub/uploads
RESOURCEHUB_UPLOAD_BASE_DIR=./storage/uploads

# ─── 이메일 도메인 (회원가입 허용 도메인) ─────────────────────
RESOURCEHUB_COMPANY_EMAIL_DOMAIN=eactive.co.kr

# ─── 최초 관리자 계정 ─────────────────────────────────────────
RESOURCEHUB_ADMIN_EMAIL=admin@eactive.co.kr
RESOURCEHUB_ADMIN_PASSWORD=changeme_strong_password

# ─── 앱 포트 (호스트 바인딩) ──────────────────────────────────
APP_PORT=8080
