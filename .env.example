# PostgreSQL (docker-compose가 사용)
POSTGRES_PASSWORD=changeme

# Spring Boot 데이터소스 (선택 — 로컬에서는 application.yml 기본값을 사용)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/resourcehub
SPRING_DATASOURCE_USERNAME=resourcehub
SPRING_DATASOURCE_PASSWORD=resourcehub

# 업로드 베이스 디렉터리
# 로컬: ./storage/uploads
# 운영 VM: /data/eactive-resource-hub/uploads
RESOURCEHUB_UPLOAD_BASE_DIR=./storage/uploads
